# Copy to .env for local development (optional)

# Backend API base URL (no trailing slash, no /api suffix)
# Production: https://horizon.ac3eplatforms.com
VITE_API_BASE=https://horizon.ac3eplatforms.com

# Optional: for local `npm run deploy` without `wrangler login`
# Token needs: Account > Workers Scripts > Edit, Account > Workers Routes > Edit,
# Zone > Workers Routes > Edit (zone: isaiash.com), User > Memberships > Read
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
