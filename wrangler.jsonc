{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "horizon-lens",
  "compatibility_date": "2026-06-09",
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "isaiash.com/horizon/*",
      "zone_name": "isaiash.com"
    },
    {
      "pattern": "isaiash.com/horizon",
      "zone_name": "isaiash.com"
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
